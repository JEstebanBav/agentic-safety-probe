    "parameters": {
      "type": "object",
      "properties": {
        "email_address": {
          "type": "string",
          "description": "Email account to check"
        },
        "limit": {
          "type": "integer",
          "description": "Number of emails to retrieve",
          "default": 10
        }
      },
      "required": [
        "email_address"
      ]
    }
  },
